{
    "name": "velt/framework",
    "description": "Official Velt framework meta-package and integration layer.",
    "type": "metapackage",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel Kaluba",
            "email": "skylore300@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "velt/kernel": "^0.1.0",
        "velt/http": "^0.1.0",
        "velt/ui": "^0.0.2",
        "velt/database": "^0.1.0",
        "velt/orm": "^0.1.0",
        "velt/cli": "^0.2.0",
        "velt/preview": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "suggest": {
        "velt/skeleton": "Install the application skeleton when starting a new Velt project."
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
